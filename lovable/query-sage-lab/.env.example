# SQLSphere frontend (Vite) - LOCAL_MODE configuration
# -----------------------------------------------------
# Copy this file to .env only if you want to run the dev server
# (`npm run dev`). The Cloudflare Pages build sets these via
# .github/workflows/deploy-frontend.yml.

# Vite only exposes variables prefixed with VITE_ to the browser bundle.

# Backend URL the browser should call. In LOCAL_MODE this is the
# FastAPI container started by `docker compose up` (or your local
# `uvicorn`). It must match (or be a subset of) the backend's
# ALLOWED_ORIGINS list.
VITE_BACKEND_URL=http://localhost:8000

# Set to "true" to enable LOCAL_MODE-specific UI (demo banner,
# disabled cloud features, no login screen). Defaults true.
VITE_LOCAL_MODE=true

# Cloud-only Supabase keys. Unused in LOCAL_MODE; listed for reference.
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_PROJECT_ID=
