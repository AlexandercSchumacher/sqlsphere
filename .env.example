# SQLSphere backend (FastAPI) - LOCAL_MODE configuration
# ------------------------------------------------------
# `docker compose up` populates these for you via docker-compose.yml.
# Copy this file to .env only if you want to run the backend without
# Docker (uvicorn directly).

# LOCAL_MODE=true switches the backend to single-user mode. Auth is
# bypassed, schedules / alerts / dashboards endpoints return 503,
# and a fixed demo user is used for all data.
LOCAL_MODE=true

# Local Postgres connection string. The default targets the postgres
# service from docker-compose.yml.
DATABASE_URL=postgresql://postgres:demo@localhost:5432/sqlsphere

# Comma-separated list of allowed CORS origins. The Cloudflare-hosted
# frontend at sqlsphere.com calls this backend at http://localhost:8000,
# so its origin must be allowed.
ALLOWED_ORIGINS=https://sqlsphere.com,http://localhost:5173,http://localhost:8080

# Server port
PORT=8000

# AI / LLM provider keys (optional; chat returns 503 if none are set).
# Set ACTIVE_MODEL to claude or chatgpt to choose the default provider.
ACTIVE_MODEL=claude
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# Cloud-only secrets. Unused in LOCAL_MODE. Listed here only so the
# file is a complete reference of the env vars the backend supports.
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
FASTAPI_AUTH_TOKEN=
RESEND_API_KEY=
